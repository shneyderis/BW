{
  "rewrites": [
    {
      "source": "/api/wc/:path*",
      "destination": "https://beykush.com/wp-json/wc/v3/:path*"
    },
    {
      "source": "/api/sp/:path*",
      "destination": "https://api.sendpulse.com/:path*"
    },
    {
      "source": "/api/meta/:path*",
      "destination": "https://graph.facebook.com/v19.0/:path*"
    }
  ]
}
